---
const { languages } = Astro.props;

const LANG_COLORS = {
  JavaScript: '#f7df1e',
  TypeScript: '#3178c6',
  PHP: '#777bb4',
  Python: '#3572A5',
  CSS: '#563d7c',
  HTML: '#e34c26',
  Vue: '#41b883',
  Rust: '#dea584',
  Go: '#00add8',
  Java: '#b07219',
  'C++': '#f34b7d',
  C: '#555555',
  Ruby: '#701516',
  Swift: '#ffac45',
  Kotlin: '#a97bff',
  Dart: '#00b4ab',
  Shell: '#89e051',
  Lua: '#000080',
  'C#': '#178600',
  Astro: '#ff5a03',
};

function getLangColor(name) {
  return LANG_COLORS[name] || '#5b8dee';
}
---

<section class="lang-section fade-up fade-up-delay-3">
  <div class="section-header">
    <h2 class="section-title">Top Languages</h2>
  </div>

  <div class="lang-card">
    <div class="lang-bar-track">
      {languages.map(lang => (
        <div
          class="lang-bar-segment"
          style={`width: ${lang.percent}%; background: ${getLangColor(lang.name)};`}
          title={`${lang.name} ${lang.percent}%`}
        ></div>
      ))}
    </div>

    <div class="lang-list">
      {languages.map((lang, i) => (
        <div class="lang-item" style={`animation-delay: ${0.05 * i}s`}>
          <div class="lang-dot" style={`background: ${getLangColor(lang.name)};`}></div>
          <span class="lang-name">{lang.name}</span>
          <div class="lang-fill-bar">
            <div
              class="lang-fill-inner"
              style={`width: ${lang.percent}%; background: ${getLangColor(lang.name)};`}
            ></div>
          </div>
          <span class="lang-percent">{lang.percent}%</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .lang-section { margin-bottom: 24px; }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 14px;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-muted);
  }

  .lang-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
    box-shadow: var(--shadow);
    overflow: hidden;
    position: relative;
  }

  .lang-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent-2), transparent);
    opacity: 0.3;
  }

  .lang-bar-track {
    display: flex;
    height: 8px;
    border-radius: 4px;
    overflow: hidden;
    gap: 2px;
    margin-bottom: 24px;
  }

  .lang-bar-segment {
    height: 100%;
    border-radius: 2px;
    transition: filter 0.2s ease;
  }

  .lang-bar-segment:hover { filter: brightness(1.3); }

  .lang-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .lang-item {
    display: grid;
    grid-template-columns: 10px 110px 1fr 48px;
    align-items: center;
    gap: 12px;
    animation: fadeUp 0.4s ease forwards;
    opacity: 0;
  }

  .lang-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .lang-name {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .lang-fill-bar {
    height: 4px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  .lang-fill-inner {
    height: 100%;
    border-radius: 2px;
    transition: width 1s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .lang-percent {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    text-align: right;
  }
</style>